# PolyMind API environment variables

# Application
APP_NAME=PolyMind API
APP_VERSION=0.1.0
DEBUG=true

# API server
API_HOST=0.0.0.0
API_PORT=8300

# Database
# Local dev (SQLite, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./polymind_dev.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/polymind
DATABASE_ECHO=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
