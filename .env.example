# PolyMind environment variables

# Application
APP_NAME=PolyMind API
APP_VERSION=0.1.0
DEBUG=true

# API backend (FastAPI)
API_HOST=0.0.0.0
API_PORT=8300

# Frontend
VITE_API_URL=http://localhost:8300
VITE_API_MOCK=false
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC=https://api.devnet.solana.com
VITE_SOLANA_WS=wss://api.devnet.solana.com
VITE_SOLANA_PROGRAM_ID=GRzZ7B6ZzgU2TuvmTFhtPHbc98CScGLw6h5McTM4SXT5
VITE_SOLANA_CHAMPION_PROGRAM_ID=

# Admin frontend proxy
ADMIN_BACKEND_URL=http://localhost:8300

# Database (PostgreSQL via Docker Compose on port 5433)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/polymind
DATABASE_ECHO=false

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,http://localhost:3200,http://127.0.0.1:3200

# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=GRzZ7B6ZzgU2TuvmTFhtPHbc98CScGLw6h5McTM4SXT5
SOLANA_CHAMPION_PROGRAM_ID=

# Auth (use strong random strings >= 32 chars in production)
JWT_SECRET=dev-jwt-secret-change-me-in-production
ADMIN_JWT_SECRET=dev-admin-jwt-secret-change-me-in-production
NONCE_TTL_SECONDS=300

# Admin bootstrap (comma-separated Solana addresses)
BACKEND_ADMIN_BOOTSTRAP=GRzZ7B6ZzgU2TuvmTFhtPHbc98CScGLw6h5McTM4SXT5
